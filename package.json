  "homepage": "https://patguettler.github.io/guardian-md/",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "GH_PAGES_BASE=/guardian-md/ GITHUB_PAGES=true npm run build",
