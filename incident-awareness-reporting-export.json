                "correct": false
              }
            ],
            "explanation": "Medication dosage errors directly affect patient safety and are classified as clinical incidents."
          },
          {
            "id": "q2",
            "text": "A water leak in the parking garage is best classified as:",
            "type": "single_select",
            "options": [
              {
                "id": "a",
