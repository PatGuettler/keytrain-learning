                "correct": true
              },
              {
                "id": "c",
                "text": "Privacy breach",
                "correct": false
              }
            ],
            "explanation": "Facilities issues without direct patient harm are physical incidents, still reportable through facilities channels."
          }
        ],
        "passing_score": 80,
